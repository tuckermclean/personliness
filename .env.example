# Django settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database settings
POSTGRES_DB=personliness
POSTGRES_USER=personliness
POSTGRES_PASSWORD=personliness
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Celery settings
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Admin API key for figure ingestion
ADMIN_API_KEY=your-admin-api-key-here

# LLM provider selection (choose one of: openai-o3, openai-gpt4, anthropic, ollama, custom)
LLM_ACTIVE_CONFIG=anthropic

# API keys for built-in profiles
LLM_OPENAI_API_KEY=your-openai-api-key-here
LLM_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: override model per profile
# LLM_OPENAI_MODEL=o3
# LLM_OPENAI_GPT4_MODEL=gpt-4-turbo
# LLM_ANTHROPIC_MODEL=claude-opus-4-6
# LLM_OLLAMA_BASE_URL=http://ollama:11434/v1
# LLM_OLLAMA_MODEL=llama3

# Backwards-compatible legacy vars (used automatically if LLM_ACTIVE_CONFIG not set)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-key-here
# LLM_MODEL=o3

# Refinement (global, applies regardless of active config)
LLM_ENABLE_REFINEMENT=False
LLM_MAX_REFINEMENT_PASSES=2
LLM_MIN_CONFIDENCE_TARGET=High

# Superuser creation (for Docker entrypoint)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme123
